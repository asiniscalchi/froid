TELEGRAM_BOT_TOKEN=
DATA_DIR=data
DATABASE_FILE=froid.sqlite3
RUST_LOG=info

# Embedding reconciliation worker (disabled by default)
FROID_EMBEDDING_WORKER_ENABLED=false
FROID_EMBEDDING_WORKER_BATCH_SIZE=20
FROID_EMBEDDING_WORKER_INTERVAL_SECONDS=300

# Extraction reconciliation worker (disabled by default)
# Retries entries with no extraction record and entries with status=failed
FROID_EXTRACTION_WORKER_ENABLED=false
FROID_EXTRACTION_WORKER_BATCH_SIZE=20
FROID_EXTRACTION_WORKER_INTERVAL_SECONDS=300

# Required when FROID_EMBEDDING_WORKER_ENABLED=true or FROID_EXTRACTION_WORKER_ENABLED=true
OPENAI_API_KEY=
